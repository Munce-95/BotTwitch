# === CONFIGURATION SPOTIFY ===
# Récupérables sur https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=votre_client_id_ici
SPOTIFY_CLIENT_SECRET=votre_client_secret_ici
SPOTIFY_REDIRECT_URI=http://localhost:8888/callback

# IDs des Playlists (trouvables dans l'URL Spotify ou via clic droit > Partager)
PLAYLIST_ID=votre_id_playlist_live
ARCHIVE_ID=votre_id_playlist_archive

# === CONFIGURATION TWITCH ===
# Token générable sur https://twitchapps.com/tmi/
TWITCH_TOKEN=oauth:votre_token_tmi
TWITCH_NICK=nom_du_compte_bot
TWITCH_CHANNEL=votre_chaine_twitch

# === PARAMÈTRES DU BOT ===
# Liste des admins séparés par des virgules (ex: pseudo1,pseudo2)
ADMINS=votre_pseudo
LIMIT_USER=5
LIMIT_MODO=10# --- COPIEZ CE FICHIER VERS .env ET REMPLISSEZ VOS INFOS ---
SPOTIFY_CLIENT_ID=votre_id
SPOTIFY_CLIENT_SECRET=votre_secret
PLAYLIST_ID=votre_playlist_id
ARCHIVE_ID=votre_playlist_archive_id

TWITCH_TOKEN=oauth:votre_token
TWITCH_NICK=votre_pseudo_bot
TWITCH_CHANNEL=votre_chaine
TWITCH_CLIENT_ID=votre_client_id

ADMINS=votre_pseudo
LIMIT_USER=5
LIMIT_MODO=10
