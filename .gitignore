# ==========================================
# GESTION DES ENVIRONNEMENTS (Python standard)
# ==========================================
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
ENV/
env/
.Python
build/
dist/
*.egg-info/
.installed.cfg
*.egg

# ==========================================
# SECRETS ET CONFIGURATION (Crucial !)
# ==========================================
.env
.envrc
.cache
.cache-*

# ==========================================
# DONNÉES DU BOT (.data)
# ==========================================

# 1. On ignore tout le contenu de .data
.data/*

# 2. SAUF les sous-dossiers (on autorise Git à "entrer" dedans)
!.data/database/
!.data/config/
!.data/security/

# 3. À l'intérieur de ces dossiers, on ignore tout...
.data/database/*
.data/config/*
.data/security/*

# 4. ...SAUF nos fichiers modèles et fichiers spécifiques
!.data/**/*.example
!.data/security/ad_bot_suspicion.txt
!.data/**/.gitkeep

# ==========================================
# OUTILS ET ÉDITEURS (VS Code, Cursor, etc.)
# ==========================================
.vscode/
.cursorignore
.cursorindexingignore
.idea/
*.log
.DS_Store
Thumbs.db

# ==========================================
# TESTS ET CACHE TOOLS
# ==========================================
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/