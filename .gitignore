# ==========================================
# GESTION DES ENVIRONNEMENTS (Python standard)
# ==========================================
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
ENV/
env/
.Python
build/
dist/
*.egg-info/
.installed.cfg
*.egg

# ==========================================
# SECRETS ET CONFIGURATION (Crucial !)
# ==========================================
# On ignore tes accès personnels et le cache Spotify
.env
.envrc
.cache
.cache-*

# ==========================================
# DONNÉES DU BOT (.data)
# ==========================================
# On ignore les données privées des viewers
.data/viewer.txt

# Optionnel : Si tu veux que ton ami ait un dossier .data vide sur GitHub
# mais sans tes fichiers de logs/viewers, tu peux décommenter la ligne suivante :
# .data/*.log

# ==========================================
# OUTILS ET ÉDITEURS (VS Code, Cursor, etc.)
# ==========================================
.vscode/
.cursorignore
.cursorindexingignore
.idea/
*.log
.DS_Store
Thumbs.db

# ==========================================
# TESTS ET CACHE TOOLS
# ==========================================
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/
