# ==========================================
# GESTION DES ENVIRONNEMENTS (Python standard)
# ==========================================
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
ENV/
env/
.Python
build/
dist/
*.egg-info/
.installed.cfg
*.egg

# ==========================================
# SECRETS ET CONFIGURATION (Crucial !)
# ==========================================
.env
.envrc
.cache
.cache-*

# ==========================================
# DONNÉES DU BOT (.data)
# ==========================================
# On ignore par défaut tout le contenu du dossier .data
.data/**/*

# --- EXCEPTIONS (On garde les fichiers nécessaires) ---

# Autoriser les fichiers modèles (.example) dans tous les sous-dossiers
!.data/**/*.example

# Autoriser spécifiquement le dictionnaire de suspicion des bots (Security)
!.data/security/ad_bot_suspicion.txt

# Optionnel : Conserver la structure des dossiers sur Git via des fichiers .gitkeep
# (Utile si tu n'as pas encore mis les .example dans chaque dossier)
!.data/**/.gitkeep

# ==========================================
# OUTILS ET ÉDITEURS (VS Code, Cursor, etc.)
# ==========================================
.vscode/
.cursorignore
.cursorindexingignore
.idea/
*.log
.DS_Store
Thumbs.db

# ==========================================
# TESTS ET CACHE TOOLS
# ==========================================
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/